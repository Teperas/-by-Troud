<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>대장간 매니저</title>
    <style>
        :root { --bg: #121212; --card: #1e1e1e; --gold: #ffcc00; --blue: #4db8ff; }
        body { background: var(--bg); color: white; font-family: sans-serif; margin: 0; padding: 15px; }
        .card { background: var(--card); border-radius: 12px; padding: 15px; margin-bottom: 15px; border: 1px solid #333; }
        .input-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .input-box { display: flex; flex-direction: column; }
        label { font-size: 12px; color: #aaa; margin-bottom: 5px; }
        input { background: #333; border: 1px solid #444; color: white; padding: 10px; border-radius: 6px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 14px; }
        th { background: #333; padding: 10px; text-align: left; color: var(--gold); border-bottom: 2px solid #444; }
        td { padding: 10px; border-bottom: 1px solid #2a2a2a; }
        .val { color: var(--blue); font-weight: bold; }
    </style>
</head>
<body>

    <h3>⚒️ 대장간 관리 정보</h3>
    <div class="card input-grid">
        <div class="input-box">
            <label>비용 감소 (%)</label>
            <input type="number" id="reduce" value="0" oninput="render()">
        </div>
        <div class="input-box">
            <label>장비 판매 가격</label>
            <input type="number" id="sell" value="0">
        </div>
        <div class="input-box">
            <label>무료 제련 기회</label>
            <input type="number" id="free" value="0">
        </div>
        <div class="input-box">
            <label>장비 최대 레벨</label>
            <input type="number" id="max" value="0">
        </div>
    </div>

    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Lv</th>
                    <th>비용</th>
                    <th>시간</th>
                </tr>
            </thead>
            <tbody id="list"></tbody>
        </table>
    </div>

<script>
    const data = [
        [2, 400, "5m"], [3, 700, "15m"], [4, 1500, "30m"], [5, 3500, "1h"],
        [6, 10000, "2h"], [7, 25000, "7h 33m"], [8, 50000, "13h 6m"], [9, 100000, "18h 39m"],
        [10, 150000, "1d 13m"], [11, 250000, "1d 11h"], [12, 336000, "2d 1h"], [13, 452000, "2d 17h"],
        [14, 612000, "3d 13h"], [15, 830000, "4d 11h"], [16, 1120000, "5d 9h"], [17, 1512000, "6d 7h"],
        [18, 2037000, "7d 6h"], [19, 2752000, "8d 4h"], [20, 3717000, "9d 2h"], [21, 5020000, "10d 53m"],
        [22, 6780000, "10d 23h"], [23, 9160000, "11d 21h"], [24, 12300000, "12d 19h"], [25, 16600000, "13d 17h"],
        [26, 20000000, "14d 15h"], [27, 24000000, "15d 14h"], [28, 28800000, "16d 12h"], [29, 34600000, "17d 10h"],
        [30, 41500000, "18d 8h"], [31, 49800000, "19d 7h"], [32, 59800000, "20d 5h"], [33, 71700000, "21d 3h"],
        [34, 86100000, "22d 1h"], [35, 103000000, "23d"]
    ];

    function fmt(n) {
        if (n >= 1000000) return (n/1000000).toFixed(1) + 'm';
        if (n >= 1000) return (n/1000).toFixed(1) + 'k';
        return n;
    }

    function render() {
        const r = document.getElementById('reduce').value || 0;
        document.getElementById('list').innerHTML = data.map(row => `
            <tr>
                <td>${row[0]}</td>
                <td class="val">${fmt(Math.floor(row[1] * (1 - r/100)))}</td>
                <td>${row[2]}</td>
            </tr>
        `).join('');
    }
    render();
</script>
</body>
</html>
